{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Current Test File",
            "program": "${workspaceRoot}/node_modules/jest/bin/jest.js",
            "args": [
                "${relativeFile}",
                "--runInBand",
                "--watchAll=false"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "windows": {
                "program": "${workspaceRoot}/node_modules/jest/bin/jest.js"
            }
        }
    ]
}